classDiagram
    direction TB
    
    class DisponibilidadController {
        +getHabitacionesDisponibles(LocalDate, String) List
    }

    class DisponibilidadService {
        +consultarDisponibilidad(LocalDate, String) List
    }

    class HabitacionRepository {
        <<interface>>
        +findByTipo_NombreTipoAndEstadoActual(String, String) List
    }

    class Habitacion {
        -String numero
        -String estadoActual
        +getPrecioBase() Double
    }

    class TipoHabitacion {
        -String nombreTipo
        -Double precioBase
        -String descripcion
        +getPrecio() Double
    }

    DisponibilidadController --> DisponibilidadService : usa
    DisponibilidadService --> HabitacionRepository : consulta
    HabitacionRepository ..> Habitacion : retorna
    Habitacion "*" --> "1" TipoHabitacion : clasificada-por