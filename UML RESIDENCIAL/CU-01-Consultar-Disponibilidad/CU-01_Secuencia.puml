@startuml CU-01_Secuencia
title CU-01 — Diagrama de Secuencia: Consultar Disponibilidad de Habitaciones

actor Cliente as actor
boundary "PaginaBusqueda"          as boundary
control  "DisponibilidadController" as control
entity   "Habitacion"               as entity

actor    ->  boundary : ingresa tipo de habitacion y fecha
boundary ->  control  : consultarDisponibilidad(tipoHabitacion, fechaConsulta)

control  ->  control  : validarFecha(fechaConsulta)

alt fecha invalida
    control  --> boundary : error fecha invalida
    boundary --> actor    : muestra mensaje de error
else fecha valida
    control  ->  entity   : obtenerHabitacionesDisponibles(tipoHabitacion, fechaConsulta)
    entity   --> control  : lista de habitaciones en estado Disponible

    alt hay habitaciones disponibles
        control  --> boundary : retorna lista de habitaciones
        boundary --> actor    : muestra numero, tipo y precio disponible
    else no hay disponibilidad
        control  --> boundary : sin resultados
        boundary --> actor    : muestra mensaje y sugiere otras opciones
    end
end

@enduml